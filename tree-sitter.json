{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "hlsplaylist",
      "camelcase": "Hlsplaylist",
      "title": "Hlsplaylist",
      "scope": "source.hlsplaylist",
      "file-types": [
        "hlsplaylist"
      ],
      "injection-regex": "^hlsplaylist$",
      "class-name": "TreeSitterHlsplaylist"
    }
  ],
  "metadata": {
    "version": "0.0.5",
    "license": "MIT",
    "description": "🌲👨 hlsplaylist (m3u, m3u8) grammar for tree-sitter",
    "authors": [
      {
        "name": "Wu",
        "email": "wuzhenyu@ustc.edu",
        "url": "https://github.com/Freed-Wu"
      }
    ],
    "links": {
      "repository": "https://github.com/Freed-Wu/tree-sitter-hlsplaylist",
      "funding": "https://github.com/Freed-Wu/tree-sitter-hlsplaylist"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "java": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true,
    "zig": true
  }
}
